<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Easy Logic Flow</title>

<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<style>

:root{
--primary:#007bff;
}

body{
font-family:Segoe UI;
margin:0;
height:100vh;
display:flex;
flex-direction:column;
background:#2d2d2d;
color:white;
}

.header{
background:#111;
padding:10px 20px;
display:flex;
justify-content:space-between;
border-bottom:1px solid #333;
}

.container{
flex:1;
display:flex;
overflow:hidden;
}

.editor{
width:35%;
border-right:1px solid #444;
display:flex;
flex-direction:column;
}

textarea{
flex:1;
background:#1e1e1e;
color:#85c1e9;
border:none;
outline:none;
padding:20px;
font-family:consolas;
font-size:15px;
resize:none;
}

.viewer{
width:65%;
background:white;
overflow:auto;
display:flex;
justify-content:center;
padding:40px;
}

button{
background:#444;
color:white;
border:none;
padding:8px 15px;
cursor:pointer;
border-radius:4px;
}

button:hover{
background:var(--primary);
}

.hint{
font-size:11px;
padding:10px;
background:#000;
color:#888;
}

</style>
</head>

<body>

<div class="header">

<div><b>EASY LOGIC FLOW</b></div>

<div>
<button onclick="downloadPNG()">📸 PNG</button>
</div>

</div>

<div class="container">

<div class="editor">

<textarea id="input">

A("Bắt đầu")

B//"Nhập số"//

C{"Kiểm tra"}

D<"Xử lý dữ liệu">

E["Thành công"]

F["Thất bại"]

A .. B
B .. C
C .Đúng. D
C .Sai. F
D .. E
E .. G("Kết thúc")

</textarea>

<div class="hint">

() = Start/End  
[] = Process  
{} = Decision  

//"text"// = Input / Output  
&lt;"text"&gt; = Subroutine  

A .. B  
A .text. B

</div>

</div>

<div class="viewer">
<div id="diagram"></div>
</div>

</div>

<script>

mermaid.initialize({
startOnLoad:false
})

function parse(text){

let lines=text.split("\n")
let out="graph TD\n"

lines.forEach(l=>{

let t=l.trim()

if(!t)return

// INPUT OUTPUT  A//"text"//
if(t.includes('//"')){
let name=t.split('//')[0].trim()
let label=t.match(/"(.*?)"/)[1]
out+=name+'[/' + label + '/]\n'
return
}

// SUBROUTINE  A<"text">
if(t.includes('<"')){
let name=t.split('<')[0].trim()
let label=t.match(/"(.*?)"/)[1]
out+=name+'[[' + label + ']]\n'
return
}

// LINK ..
if(t.includes(".."))
{
let p=t.split("..")
out+=p[0].trim()+" --> "+p[1].trim()+"\n"
return
}

// LINK TEXT
if(t.includes(".") && !t.includes(".."))
{
let p=t.split(".")
if(p.length>=3)
{
out+=p[0].trim()+" -- "+p[1].trim()+" --> "+p[2].trim()+"\n"
return
}
}

out+=t+"\n"

})

return out
}

async function render(){

let raw=document.getElementById("input").value

let code=parse(raw)

let el=document.getElementById("diagram")

el.innerHTML=""

let {svg}=await mermaid.render("graphDiv",code)

el.innerHTML=svg

}

document.getElementById("input").addEventListener("input",render)

async function downloadPNG(){

let canvas=await html2canvas(document.querySelector(".viewer"))

let a=document.createElement("a")

a.href=canvas.toDataURL()

a.download="flowchart.png"

a.click()

}

render()

</script>

</body>
</html>
