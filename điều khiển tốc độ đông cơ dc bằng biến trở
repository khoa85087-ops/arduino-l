
int ENB = 10;
int IN1 = 9;
int IN2 = 8;
int sensorPin = A0;

void setup() {
  pinMode(ENB, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);

}

void loop() {
  int value = analogRead(sensorPin);   

 
  int pwm = map(value, 0, 1023, 0, 255);


  pwm = constrain(pwm, 0, 255);

 
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);

 
  analogWrite(ENB, pwm);

  delay(50);
}
