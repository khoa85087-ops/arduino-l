<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Easy Logic Flow</title>
    <script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        :root { --primary: #007bff; --dark: #1e1e1e; }
        body { font-family: 'Segoe UI', sans-serif; display: flex; flex-direction: column; height: 100vh; margin: 0; background: #2d2d2d; color: white; }
        .header { background: #111; padding: 10px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #333; }
        .container { display: flex; flex: 1; overflow: hidden; }
        
        /* Editor */
        .editor-container { width: 35%; display: flex; flex-direction: column; border-right: 1px solid #444; }
        textarea { flex: 1; padding: 20px; font-family: 'Consolas', monospace; font-size: 15px; border: none; outline: none; background: var(--dark); color: #85c1e9; line-height: 1.6; resize: none; }
        
        /* Viewer */
        #viewer { width: 65%; background: white; overflow: auto; display: flex; justify-content: center; padding: 40px; }
        
        /* Controls */
        button { background: #444; color: white; border: none; padding: 8px 15px; border-radius: 4px; cursor: pointer; margin-left: 5px; }
        button:hover { background: var(--primary); }
        .status { font-size: 12px; color: #888; margin-right: 10px; }
        .hint { font-size: 11px; color: #555; padding: 10px; background: #000; }
    </style>
</head>
<body>

<div class="header">
    <div><strong>EASY LOGIC FLOW</strong> <span class="status" id="status">Sẵn sàng</span></div>
    <div>
        <button onclick="downloadImage()" style="background: #27ae60;">📸 Tải ảnh PNG</button>
    </div>
</div>

<div class="container">
    <div class="editor-container">
        <textarea id="inputText" oninput="processAndRender()" placeholder="Gõ logic vào đây...">
A("Bắt đầu")
B{"Kiểm tra"}
C["Thành công"]
D["Thất bại"]

A .. B
B .Đúng. C
B .Sai. D
C .. E("Kết thúc")
        </textarea>
        <div class="hint">
            Mẹo: A("Tròn") | B["Vuông"] | C{"Nhọn"} <br>
            Nối: A .. B (Trống) | A .Text. B (Có chữ)
        </div>
    </div>
    
    <div id="viewer">
        <div class="mermaid" id="mermaidContainer"></div>
    </div>
</div>

<script>
    mermaid.initialize({ startOnLoad: true, theme: 'default' });

    let timeout = null;

    function parseCustomSyntax(text) {
        let lines = text.split('\n');
        let output = "graph TD\n";

        lines.forEach(line => {
            let trimmed = line.trim();
            if (!trimmed || trimmed.startsWith('%%')) return;

            // 1. Xử lý nối có text: A .Nội dung. B  =>  A -- Nội dung --> B
            if (trimmed.includes('.') && !trimmed.includes('..')) {
                let parts = trimmed.split('.');
                if (parts.length >= 3) {
                    let from = parts[0].trim();
                    let label = parts[1].trim();
                    let to = parts[2].trim();
                    output += `    ${from} -- "${label}" --> ${to}\n`;
                    return;
                }
            }

            // 2. Xử lý nối không text: A .. B  =>  A --> B
            if (trimmed.includes('..')) {
                let parts = trimmed.split('..');
                output += `    ${parts[0].trim()} --> ${parts[1].trim()}\n`;
                return;
            }

            // 3. Giữ nguyên các định nghĩa khối A("Bắt đầu"), B["Xử lý"]
            output += `    ${trimmed}\n`;
        });

        return output;
    }

    function processAndRender() {
        document.getElementById('status').innerText = "Đang vẽ...";
        clearTimeout(timeout);
        
        timeout = setTimeout(() => {
            const rawText = document.getElementById('inputText').value;
            const mermaidSyntax = parseCustomSyntax(rawText);
            const container = document.getElementById('mermaidContainer');
            
            try {
                container.removeAttribute('data-processed');
                container.innerHTML = mermaidSyntax;
                mermaid.contentLoaded();
                document.getElementById('status').innerText = "Đã cập nhật";
            } catch (e) {
                document.getElementById('status').innerText = "Lỗi cú pháp!";
            }
        }, 300);
    }

    async function downloadImage() {
        const viewer = document.getElementById('viewer');
        const canvas = await html2canvas(viewer);
        const link = document.createElement('a');
        link.download = 'logic-flow.png';
        link.href = canvas.toDataURL();
        link.click();
    }

    window.onload = processAndRender;
</script>

</body>
</html>
