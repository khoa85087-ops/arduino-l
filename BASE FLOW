<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Easy Logic Flow Pro</title>
    <script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        :root { --primary: #007bff; --bg-editor: #1e1e1e; --bg-header: #111; }
        body { font-family: 'Segoe UI', sans-serif; display: flex; flex-direction: column; height: 100vh; margin: 0; background: #2d2d2d; color: white; overflow: hidden; }
        .header { background: var(--bg-header); padding: 10px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #333; }
        .container { display: flex; flex: 1; overflow: hidden; }
        
        /* Editor Area */
        .editor-container { width: 35%; display: flex; flex-direction: column; border-right: 1px solid #444; }
        textarea { flex: 1; padding: 20px; font-family: 'Consolas', monospace; font-size: 15px; border: none; outline: none; background: var(--bg-editor); color: #85c1e9; line-height: 1.6; resize: none; }
        
        /* Viewer Area */
        #viewer { width: 65%; background: white; overflow: auto; display: flex; flex-direction: column; align-items: center; padding: 40px; position: relative; }
        
        /* Controls */
        button { background: #444; color: white; border: none; padding: 8px 15px; border-radius: 4px; cursor: pointer; margin-left: 5px; font-weight: 500; }
        button:hover { background: var(--primary); }
        .btn-green { background: #27ae60; }
        .status { font-size: 12px; color: #888; margin-right: 10px; }
        .hint-bar { font-size: 11px; color: #777; padding: 10px; background: #000; display: flex; justify-content: space-between; }
    </style>
</head>
<body>

<div class="header">
    <div><strong>EASY LOGIC FLOW PRO</strong> <span class="status" id="status">Đã lưu</span></div>
    <div>
        <button onclick="toggleDirection()">Đổi hướng (Dọc/Ngang)</button>
        <button onclick="downloadImage()" class="btn-green">📸 Tải ảnh PNG</button>
    </div>
</div>

<div class="container">
    <div class="editor-container">
        <textarea id="inputText" oninput="processAndRender()" placeholder="Gõ logic vào đây...">
A("Bắt đầu")
B{"Kiểm tra"}
C["Thành công"]
D["Thất bại"]

A .. B
B .Đúng. C
B .Sai. D
C .. E("Kết thúc")

%% Thử đổi màu:
style A fill:#f96
style C fill:#9f9
        </textarea>
        <div class="hint-bar">
            <span>A("Tròn") | B["Vuông"] | C{"Nhọn"}</span>
            <span>Nối: .. hoặc .Text.</span>
        </div>
    </div>
    
    <div id="viewer">
        <div class="mermaid" id="mermaidContainer"></div>
    </div>
</div>

<script>
    mermaid.initialize({ startOnLoad: true, theme: 'default', flowchart: { useMaxWidth: false, htmlLabels: true } });

    let timeout = null;
    let currentDir = "TD"; // TD: Top-Down, LR: Left-Right

    // Load dữ liệu cũ khi mở app
    if(localStorage.getItem('savedLogic')) {
        document.getElementById('inputText').value = localStorage.getItem('savedLogic');
    }

    function toggleDirection() {
        currentDir = (currentDir === "TD") ? "LR" : "TD";
        processAndRender();
    }

    function parseCustomSyntax(text) {
        let lines = text.split('\n');
        let output = `graph ${currentDir}\n`;

        lines.forEach(line => {
            let trimmed = line.trim();
            if (!trimmed) return;

            // Xử lý nối có text: A .Nội dung. B
            if (trimmed.includes('.') && !trimmed.includes('..') && !trimmed.startsWith('style') && !trimmed.startsWith('%%')) {
                let parts = trimmed.split('.');
                if (parts.length >= 3) {
                    output += `    ${parts[0].trim()} -- "${parts[1].trim()}" --> ${parts[2].trim()}\n`;
                    return;
                }
            }

            // Xử lý nối không text: A .. B
            if (trimmed.includes('..')) {
                let parts = trimmed.split('..');
                output += `    ${parts[0].trim()} --> ${parts[1].trim()}\n`;
                return;
            }

            // Các lệnh style hoặc định nghĩa khối giữ nguyên
            output += `    ${trimmed}\n`;
        });

        return output;
    }

    function processAndRender() {
        document.getElementById('status').innerText = "Đang lưu...";
        clearTimeout(timeout);
        
        timeout = setTimeout(() => {
            const rawText = document.getElementById('inputText').value;
            localStorage.setItem('savedLogic', rawText); // Lưu vào máy
            
            const mermaidSyntax = parseCustomSyntax(rawText);
            const container = document.getElementById('mermaidContainer');
            
            try {
                container.removeAttribute('data-processed');
                container.innerHTML = mermaidSyntax;
                mermaid.contentLoaded();
                document.getElementById('status').innerText = "Đã lưu vào máy";
            } catch (e) {
                document.getElementById('status').innerText = "Lỗi cú pháp!";
            }
        }, 300);
    }

    async function downloadImage() {
        const viewer = document.getElementById('viewer');
        const canvas = await html2canvas(viewer, { backgroundColor: '#ffffff' });
        const link = document.createElement('a');
        link.download = 'logic-flow-' + Date.now() + '.png';
        link.href = canvas.toDataURL();
        link.click();
    }

    window.onload = processAndRender;
</script>

</body>
</html>
